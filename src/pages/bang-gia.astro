---
import Layout from "@/components/layout/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";
---

<Layout
  title="Bảng giá AAC79 PLUS tháng 5/2026"
  description="Bảng giá AAC79 PLUS cập nhật tháng 5/2026. Liên hệ AAC79 PLUS để được báo giá chính xác theo khối lượng và địa điểm công trình."
>
  <section class="pt-32 pb-18">
    <Container>
      <div class="mx-auto max-w-4xl text-center">
        <span class="block text-sm font-bold uppercase tracking-[0.18em] text-brand">Bảng giá mới nhất</span>
        <h1 class="mt-3 text-balance text-[clamp(2rem,4vw,3.25rem)] font-bold leading-tight text-brand-darkest">
          Bảng giá AAC79 PLUS
        </h1>
        <p class="mt-3 text-base leading-relaxed text-ink-600 sm:text-lg">
          Cập nhật tháng 5/2026 – Liên hệ để chốt giá tốt nhất
        </p>
      </div>

      <div class="mx-auto mt-7 max-w-3xl rounded-2xl bg-ink-50 px-5 py-4 text-center text-sm leading-relaxed text-ink-600">
        Giá trên chưa bao gồm chi phí vận chuyển. Liên hệ để được báo giá chính xác theo khối lượng và địa điểm công trình.
      </div>

      <div class="mx-auto mt-5 flex flex-col items-start gap-3 sm:items-center">
        <a href="tel:0907523113" class="inline-flex items-center justify-start gap-2 rounded-lg bg-white px-7 py-4 text-left text-base font-bold text-brand-darkest ring-1 ring-ink-200 transition-colors hover:bg-brand-pale">
          <Icon name="headset" class="h-7 w-7" /> Tư vấn: 0907 523 113
        </a>
      </div>

      <div class="mx-auto mt-8 max-w-5xl overflow-hidden rounded-3xl border border-ink-200 bg-white shadow-soft">
        <img src="/images/bao-gia-thang-5-2026.png" alt="Bảng giá AAC79 PLUS tháng 5/2026" class="w-full" />
      </div>
    </Container>
  </section>
</Layout>
