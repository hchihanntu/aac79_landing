---
import Layout from "@/components/layout/Layout.astro";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";

const pdfUrl = "/AAC79PRO - Hồ sơ Năng lực 2026 (Thẩm định KC).pdf";
---

<Layout
  title="Hồ sơ năng lực – AAC79 PROTECH"
  description="Hồ sơ năng lực AAC79 PROTECH 2026 về thẩm định kết cấu, kiểm định và quan trắc sức khỏe công trình."
>
  <section class="bg-brand-darkest pt-32 pb-14 text-white lg:pt-38 lg:pb-18">
    <Container>
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8" data-aos="fade-up">
          <h1 class="text-balance text-[clamp(2rem,4vw,3.8rem)] font-bold uppercase leading-tight">
            Hồ sơ năng lực AAC79 PROTECH
          </h1>
          <p class="mt-5 max-w-3xl text-base leading-relaxed text-white/78 sm:text-lg">
            Dưới đây là tài liệu năng lực 2026 về thẩm định kết cấu, kiểm định công trình, quan trắc sức khỏe công trình và các giải pháp công nghệ BIM-UAV-Digital Twin.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:col-span-4 lg:justify-end" data-aos="fade-up" data-aos-delay="100">
          <Button href={pdfUrl} target="_blank" variant="orange" size="lg">
            <Icon name="document-text" class="h-6 w-6" />
            Mở PDF
          </Button>
          <a
            href={pdfUrl}
            download
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/25 px-7 py-4 text-base font-bold text-white transition-colors hover:bg-white/10"
          >
            <Icon name="arrow-right" class="h-5 w-5" />
            Tải xuống
          </a>
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-ink-50 py-10 lg:py-14">
    <Container>
      <div class="border border-ink-200 bg-white p-3" data-aos="fade-up">
        <iframe
          src={pdfUrl}
          title="Hồ sơ năng lực AAC79 PROTECH 2026"
          class="h-[72vh] min-h-[520px] w-full bg-ink-50"
        ></iframe>
      </div>
      <p class="mt-4 text-sm leading-relaxed text-ink-600">
        Nếu trình duyệt không hiển thị PDF trực tiếp, vui lòng dùng nút “Mở PDF” hoặc “Tải xuống” phía trên.
      </p>
    </Container>
  </section>
</Layout>
