---
import Layout from "@/components/layout/Layout.astro";
import LeadForm from "@/components/sections/LeadForm.astro";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";

const serviceCards = [
  {
    title: "Kiểm định dân dụng",
    href: "#kiem-dinh-dan-dung",
    icon: "building-office",
  },
  {
    title: "Kiểm định nhà xưởng",
    href: "#kiem-dinh-nha-xuong",
    icon: "hardhat",
  },
  {
    title: "Kiểm định hạ tầng",
    href: "#kiem-dinh-ha-tang",
    icon: "map",
  },
];

const purposes = [
  {
    title: "Xin phép cải tạo, hoàn công",
    icon: "document-text",
  },
  {
    title: "Cải tạo, nâng tầng, thay đổi công năng",
    icon: "adjustments-horizontal",
  },
  {
    title: "Thẩm tra, nghiệm thu và giải quyết tranh chấp",
    icon: "scale",
  },
];

const inspectionSections = [
  {
    id: "kiem-dinh-dan-dung",
    title: "Kiểm định dân dụng",
    items: [
      "Kiểm định nhà riêng lẻ",
      "Kiểm định chung cư",
      "Kiểm định biệt thự",
      "Kiểm định khách sạn",
      "Kiểm định trường học - trung tâm Anh Ngữ",
      "Kiểm định cải tạo nâng tầng",
    ],
    images: [
      "/images/kiemdinh-nhadandung-1.png",
      "/images/kiemdinh-nhadandung-2.png",
    ],
  },
  {
    id: "kiem-dinh-ha-tang",
    title: "Kiểm định hạ tầng",
    items: [
      "Kiểm định nền móng",
      "Kiểm định đường nội bộ",
      "Kiểm định hệ thống thoát nước",
      "Kiểm định tường chắn - kè",
      "Kiểm định hạ tầng kỹ thuật khu công nghiệp",
    ],
    images: ["/images/kiemdinh-nenmong-1.png"],
    reverse: true,
  },
  {
    id: "kiem-dinh-nha-xuong",
    title: "Kiểm định nhà xưởng",
    items: [
      "Kiểm định kết cấu nhà xưởng",
      "Kiểm định nâng tầng nhà xưởng",
      "Kiểm định nhà xưởng cũ > 10 năm",
      "Kiểm định thay đổi công năng",
      "Kiểm định phục vụ PCCC",
    ],
    images: [
      "/images/kiemdinh-nhaxuong-1.png",
      "/images/kiemdinh-nhaxuong-2.png",
    ],
  },
];

const factoryProjects = [
  ["1", "Xưởng Cơ khí Tuyết Hảo", "KCN Diên Phú, Tỉnh Khánh Hòa"],
  ["2", "Nhà máy Yến Sào NT", "KCN Diên Phú, Tỉnh Khánh Hòa"],
  ["3", "Xưởng bao bì Hiệp Hưng", "KCN Suối Dầu, Tỉnh Khánh Hòa"],
  ["4", "Nhà máy SX Hải Vương", "KCN Suối Dầu, Tỉnh Khánh Hòa"],
];

const capabilities = [
  "Theo dõi sức khỏe công trình",
  "An toàn công trình",
  "Số hóa công trình xây dựng",
  "Dịch vụ công nghệ cao khác",
];

const clientGroups = [
  {
    title: "Các KCN tại Khánh Hòa và Nam Trung Bộ",
    text: "Suối Dầu, Diên Phú, Đắc Lộc, Trảng É, Nam Vân Phong, Cam Ranh...",
    icon: "map",
  },
  {
    title: "Nhà máy & xưởng sản xuất",
    text: "Cơ khí Vina, Hải Vương và rất nhiều xưởng dệt may, chế biến thủy sản, vật liệu xây dựng...",
    icon: "hardhat",
  },
  {
    title: "Chủ đầu tư dự án bất động sản dân dụng",
    text: "Vingroup, Sungroup, HUD, Hưng Thịnh...",
    icon: "building-office",
  },
];
---

<Layout
  title="Kiểm định công trình – AAC79 PROTECH"
  description="AAC79 PROTECH ứng dụng BIM-UAV-Digital Twin trong kiểm định, thẩm định và quan trắc sức khỏe công trình tại Khánh Hòa và Nam Trung Bộ."
>
  <section class="relative overflow-hidden bg-brand-darkest pt-32 pb-18 lg:pt-38 lg:pb-24">
    <div
      class="absolute inset-0 -z-0 bg-cover bg-center"
      style="background-image: linear-gradient(112deg, rgba(6,32,20,0.94) 0%, rgba(18,82,50,0.84) 52%, rgba(6,32,20,0.62) 100%), url('/images/hero-kiem-dinh-cong%20trinh.png');"
    ></div>
    <Container class="relative z-10">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <h1 class="text-balance text-[clamp(2rem,4vw,3rem)] font-bold uppercase leading-tight text-white" data-aos="fade-up">
            Kiểm định công trình bằng hệ sinh thái số BIM-UAV-Digital Twin
          </h1>
          <div class="mt-5 max-w-3xl space-y-4 text-base leading-relaxed text-white/84 sm:text-lg" data-aos="fade-up" data-aos-delay="100">
            <p><strong class="text-white">AAC79 PROTECH</strong> là đơn vị tiên phong tại Nam Trung Bộ ứng dụng hệ sinh thái số BIM-UAV-Digital Twin vào thẩm định và quan trắc sức khỏe công trình.</p>
            <p><strong class="text-white">Với đội ngũ chuyên gia</strong> giàu kinh nghiệm, chúng tôi biến những dữ liệu kỹ thuật khô khan thành giải pháp tối ưu, giúp Chủ đầu tư kiểm soát rủi ro và tiết kiệm chi phí trong suốt vòng đời công trình.</p>
          </div>
          <div class="mt-8" data-aos="fade-up" data-aos-delay="160">
            <Button href="#leadform" variant="orange" size="lg">
              <Icon name="headset" class="h-6 w-6" />
              Liên hệ tư vấn
            </Button>
          </div>
        </div>
        <div class="lg:col-span-4" data-aos="fade-up" data-aos-delay="220">
          <div class="rounded-2xl border border-white/15 bg-white/8 p-6 text-white backdrop-blur">
            <p class="text-5xl font-bold leading-none text-brand-vivid">30+</p>
            <p class="mt-3 text-sm leading-relaxed text-white/75">Nhà máy, kho xưởng đã được thẩm định, kiểm định và nghiệm thu.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-white py-18" id="dich-vu">
    <Container>
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-[clamp(1.7rem,3vw,2.5rem)] font-bold leading-tight text-brand-darkest">Các dịch vụ</h2>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-600">Tập trung vào kiểm định hiện trạng, đánh giá an toàn và đề xuất phương án kỹ thuật phù hợp với mục tiêu đầu tư.</p>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
        {serviceCards.map((service, index) => (
          <a href={service.href} class="group rounded-xl border border-ink-200 bg-ink-50 p-7 transition-colors hover:border-brand-light hover:bg-white" data-aos="fade-up" data-aos-delay={index * 80}>
            <Icon name={service.icon} class="h-10 w-10 text-brand" />
            <h3 class="mt-5 text-xl font-bold text-brand-darkest">{service.title}</h3>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-orange">
              Xem chi tiết <Icon name="arrow-right" class="h-4 w-4" />
            </span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <section class="bg-ink-50 py-18">
    <Container>
      <h2 class="text-center text-[clamp(1.5rem,2.4vw,2.1rem)] font-bold text-brand-darkest">Kiểm định phục vụ</h2>
      <div class="mt-9 grid grid-cols-1 gap-5 md:grid-cols-3">
        {purposes.map((purpose, index) => (
          <div class="rounded-xl border border-ink-200 bg-white p-7 text-center" data-aos="fade-up" data-aos-delay={index * 80}>
            <Icon name={purpose.icon} class="mx-auto h-11 w-11 text-brand" />
            <h3 class="mt-5 text-base font-bold leading-snug text-brand-darkest">{purpose.title}</h3>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section class="bg-white py-20">
    <Container>
      <div class="space-y-20">
        {inspectionSections.map((section) => (
          <div id={section.id} class={`grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-center ${section.reverse ? "" : ""}`}>
            <div class:list={["lg:col-span-5", section.reverse && "lg:order-2"]} data-aos="fade-up">
              <h2 class="text-[clamp(1.6rem,3vw,2.5rem)] font-bold leading-tight text-brand-darkest">{section.title}</h2>
              <ul class="mt-6 grid gap-3">
                {section.items.map((item) => (
                  <li class="flex items-start gap-3 text-base font-medium text-ink-600">
                    <Icon name="check-circle" class="mt-0.5 h-5 w-5 text-brand-light" />
                    {item}
                  </li>
                ))}
              </ul>
              <div class="mt-7">
                <Button href="#leadform" variant="orange" size="lg">
                  <Icon name="headset" class="h-6 w-6" />
                  Liên hệ tư vấn {section.title.toLowerCase()}
                </Button>
              </div>
            </div>
            <div class:list={["lg:col-span-7", section.reverse && "lg:order-1"]} data-aos="fade-up" data-aos-delay="120">
              {section.images.length === 1 ? (
                <div class="relative px-3 pb-8 pt-3 sm:px-4 sm:pt-4">
                  <div class="absolute inset-3 -z-10 rounded-2xl bg-brand-pale sm:inset-4"></div>
                  <div class="overflow-hidden rounded-2xl border border-ink-200 bg-white p-2 shadow-sm">
                    <img src={section.images[0]} alt={section.title} class="h-[320px] w-full rounded-xl object-cover sm:h-[420px]" loading="lazy" />
                  </div>
                  <div class="absolute -bottom-1 left-7 flex items-center gap-1.5 rounded-lg bg-brand-darkest px-4 py-2.5 text-sm font-bold text-white shadow-lg sm:left-9">
                    <Icon name="photo" class="h-4 w-4" /> Hiện trường thực tế
                  </div>
                </div>
              ) : (
                <div class="relative px-3 pb-8 pt-3 sm:px-4 sm:pt-4">
                  <div class="absolute inset-3 -z-10 rounded-2xl bg-brand-pale sm:inset-4"></div>
                  <div class="grid grid-cols-12 gap-4 items-end">
                    <div class="col-span-7 overflow-hidden rounded-2xl border border-ink-200 bg-white p-2 shadow-sm">
                      <img src={section.images[0]} alt={section.title} class="h-[280px] w-full rounded-xl object-cover sm:h-[430px]" loading="lazy" />
                    </div>
                    <div class="col-span-5 overflow-hidden rounded-2xl border border-ink-200 bg-white p-2 shadow-sm">
                      <img src={section.images[1]} alt={section.title} class="h-[200px] w-full rounded-xl object-cover sm:h-[310px]" loading="lazy" />
                    </div>
                  </div>
                  <div class="absolute -bottom-1 left-7 flex items-center gap-1.5 rounded-lg bg-brand-darkest px-4 py-2.5 text-sm font-bold text-white shadow-lg sm:left-9">
                    <Icon name="photo" class="h-4 w-4" /> Hiện trường thực tế
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section id="nang-luc" class="bg-brand-darkest py-20 text-white">
    <Container>
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12">
        <div class="lg:col-span-4" data-aos="fade-up">
          <Icon name="shield-check" class="h-12 w-12 text-brand-vivid" />
          <h2 class="mt-5 text-[clamp(1.7rem,3vw,2.6rem)] font-bold leading-tight">Năng lực</h2>
          <p class="mt-4 text-base leading-relaxed text-white/75">AAC79 PROTECH kết hợp kiểm định truyền thống với công nghệ số để phục vụ các yêu cầu kỹ thuật phức tạp.</p>
        </div>
        <div class="lg:col-span-8" data-aos="fade-up" data-aos-delay="100">
          <div class="rounded-2xl border border-white/15 bg-white/8 p-6">
            <h3 class="text-xl font-bold text-brand-vivid">Thẩm tra kết cấu trong điều kiện cháy</h3>
            <div class="mt-5 overflow-x-auto">
              <table class="w-full min-w-[620px] text-left text-sm">
                <thead class="border-b border-white/20 text-white/70">
                  <tr>
                    <th class="w-14 py-3 font-semibold">STT</th>
                    <th class="py-3 font-semibold">Tên công trình</th>
                    <th class="py-3 font-semibold">Địa chỉ</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/12">
                  {factoryProjects.map((project) => (
                    <tr>
                      <td class="py-4 text-white/65">{project[0]}</td>
                      <td class="py-4 font-semibold text-white">{project[1]}</td>
                      <td class="py-4 text-white/75">{project[2]}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="mt-5 text-sm text-white/70">Và hơn 30 nhà máy, kho xưởng khác đã được thẩm định và nghiệm thu.</p>
          </div>

          <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {capabilities.map((item) => (
              <div class="rounded-xl border border-white/15 bg-white/8 p-5 font-semibold text-white/90">
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="bg-ink-50 py-20">
    <Container>
      <div data-aos="fade-up">
        <h2 class="text-center text-[clamp(1.7rem,3vw,2.6rem)] font-bold leading-tight text-brand-darkest">Khách hàng & chủ đầu tư</h2>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
        {clientGroups.map((client, index) => (
          <div class="rounded-xl border border-ink-200 bg-white p-7" data-aos="fade-up" data-aos-delay={index * 80}>
            <Icon name={client.icon} class="h-11 w-11 text-brand" />
            <h3 class="mt-5 text-lg font-bold leading-snug text-brand-darkest">{client.title}</h3>
            <p class="mt-3 text-sm font-medium leading-relaxed text-ink-600">{client.text}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <LeadForm />
</Layout>
