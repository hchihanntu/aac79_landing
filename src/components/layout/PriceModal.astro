---
import Icon from "@/components/ui/Icon.astro";
---

<div
  id="price-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-[#06180f]/72 p-5 backdrop-blur-sm"
>
  <div class="flex max-h-[90vh] w-full max-w-xl flex-col overflow-hidden rounded-3xl border border-ink-200 bg-white">
    <div class="flex shrink-0 items-start justify-between gap-3 border-b border-ink-200 px-6 py-5">
      <div>
        <h3 class="flex items-center gap-2 text-lg font-bold text-brand-darkest">
          <Icon name="banknotes" class="h-5 w-5 text-brand" />
          Bảng giá AAC79 PLUS
        </h3>
        <p class="mt-1 text-sm text-ink-400">Cập nhật tháng 5/2026 – Liên hệ để chốt giá tốt nhất</p>
      </div>
      <button
        id="price-modal-close"
        type="button"
        aria-label="Đóng"
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-ink-100 text-ink-600 transition-colors hover:bg-red-100 hover:text-red-600"
      >
        <Icon name="x-mark" class="h-5 w-5" />
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5">
      <img src="/images/bao-gia-thang-5-2026.png" alt="Bảng giá AAC79 PLUS tháng 5/2026" class="mb-4 w-full rounded-xl border border-ink-200" />
      <p class="text-center text-sm leading-relaxed text-ink-600">
        Giá trên chưa bao gồm chi phí vận chuyển.<br />
        Liên hệ để được báo giá chính xác theo khối lượng &amp; địa điểm công trình.
      </p>
    </div>

    <div class="flex shrink-0 flex-col gap-3 border-t border-ink-200 px-6 py-5 sm:flex-row">
      <a href="tel:0907523113" class="flex flex-1 flex-col items-center gap-0.5 rounded-lg bg-brand px-4 py-3 text-center text-white transition-colors hover:bg-brand-darkest">
        <span class="flex items-center gap-1.5 text-sm font-bold"><Icon name="headset" class="h-4 w-4" /> Tư vấn kỹ thuật</span>
        <small class="text-xs opacity-85">0907 523 113 (Mr Hân)</small>
      </a>
      <a href="tel:0976228311" class="flex flex-1 flex-col items-center gap-0.5 rounded-lg bg-orange px-4 py-3 text-center text-white transition-colors hover:bg-orange-dark">
        <span class="flex items-center gap-1.5 text-sm font-bold"><Icon name="shopping-cart" class="h-4 w-4" /> Đặt hàng / Báo giá</span>
        <small class="text-xs opacity-85">0976 228 311 (Ms Đoan)</small>
      </a>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("price-modal");

  function openPriceModal() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closePriceModal() {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.getElementById("price-modal-close")?.addEventListener("click", closePriceModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closePriceModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closePriceModal();
  });
  document.getElementById("heroQuoteBtn")?.addEventListener("click", openPriceModal);
</script>
