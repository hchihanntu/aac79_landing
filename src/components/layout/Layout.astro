---
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import FloatButtons from "@/components/layout/FloatButtons.astro";
import PriceModal from "@/components/layout/PriceModal.astro";
import "@/styles/global.css";

const {
  title = "AAC79 PLUS – Đại lý phân phối chính thức Bê Tông Khí Tân Kỷ Nguyên Tại Khánh Hòa",
  description = "AAC79 PLUS chuyên phân phối và thi công bê tông khí chưng áp (AAC/EBlock) tại Khánh Hòa và Nam Trung Bộ. Giải pháp trọn gói – Green & Lean Construction.",
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="overflow-x-hidden antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatButtons />
    <PriceModal />
    <script src="@/lib/aos.js"></script>
  </body>
</html>
