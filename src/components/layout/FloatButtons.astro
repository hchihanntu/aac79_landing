---
import Icon from "@/components/ui/Icon.astro";
---

<div class="fixed right-5 bottom-7 z-[60] flex flex-col items-end gap-3">
  <a
    href="https://zalo.me/0976228311"
    target="_blank"
    title="Zalo đặt hàng – Ms Đoan: 0976 228 311"
    class="flex items-center gap-2.5 rounded-full bg-[#0068ff] px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-[#0052cc]"
  >
    <Icon name="chat-bubble" class="h-5 w-5" />
    <span class="hidden sm:inline">Đặt hàng qua Zalo</span>
  </a>
  <a
    href="tel:0976228311"
    title="Gọi đặt hàng – Ms Đoan: 0976 228 311"
    class="relative flex items-center gap-2.5 rounded-full bg-brand px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-brand-darkest animate-pulse-ring"
  >
    <Icon name="phone" class="h-5 w-5" />
    <span class="hidden sm:inline">Đặt hàng: 0976 228 311</span>
  </a>
</div>
