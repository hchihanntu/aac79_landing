---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import { profiles } from "@/data/ho-so-nang-luc";

const navItems = [
  { href: "/#hero", label: "Trang chủ" },
  { href: "/kiem-dinh-cong-trinh/", label: "Dịch vụ kiểm định công trình" },
  {
    href: "/ho-so-nang-luc/aac79-protech/",
    label: "Hồ sơ năng lực",
    children: profiles.map((p) => ({
      href: `/ho-so-nang-luc/${p.slug}/`,
      label: p.navLabel,
    })),
  },
  {
    href: "/#hero",
    label: "AAC79 PLUS",
    children: [
      { href: "/bang-gia/", label: "Báo giá" },
      { href: "/#solution", label: "Giải pháp" },
      { href: "/#benefits", label: "Lợi ích" },
      { href: "/#products", label: "Sản phẩm" },
      { href: "/#services", label: "Dịch vụ thi công" },
    ],
  },
  {
    href: "/kiem-dinh-cong-trinh/",
    label: "AAC79 PROTECH",
    children: [
      { href: "/kiem-dinh-cong-trinh/#dich-vu", label: "Các dịch vụ" },
      { href: "/kiem-dinh-cong-trinh/#kiem-dinh-dan-dung", label: "Kiểm định dân dụng" },
      { href: "/kiem-dinh-cong-trinh/#kiem-dinh-ha-tang", label: "Kiểm định hạ tầng" },
      { href: "/kiem-dinh-cong-trinh/#kiem-dinh-nha-xuong", label: "Kiểm định nhà xưởng" },
    ],
  },
];

const { transparentOnTop = false } = Astro.props;
---

<header
  id="header"
  class={`fixed inset-x-0 top-0 z-50 transition-colors duration-300 ${transparentOnTop ? "bg-transparent" : "bg-brand-darkest/95"}`}
  data-transparent-on-top={transparentOnTop ? "true" : "false"}
  data-scrolled-class="bg-brand-darkest/95"
>
  <Container>
    <nav class="flex h-17 items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="/" class="flex items-center gap-2.5">
          <img
            src="/images/logo-aac79.png"
            alt="AAC79 PLUS"
            width="2560"
            height="919"
            fetchpriority="high"
            decoding="async"
            class="h-11 w-auto object-contain"
          />
        </a>

        <ul class="hidden items-center gap-1 lg:flex">
          {navItems.map((item) => (
            <li class:list={["relative", item.children && "group"]}>
              <a href={item.href} class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-semibold text-white/85 transition-colors hover:bg-white/10 hover:text-white group-hover:bg-white/10 group-hover:text-white">
                {item.label}
                {item.children && <Icon name="chevron-down" class="h-4 w-4 transition-transform group-hover:rotate-180" />}
              </a>
              {item.children && (
                <div class="invisible absolute left-0 top-full w-[min(28rem,calc(100vw-2rem))] translate-y-2 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                  <div class="overflow-hidden rounded-xl border border-white/10 bg-brand-darkest/98 p-2 shadow-2xl shadow-black/25 backdrop-blur-md">
                    {item.children.map((child) => (
                      <a href={child.href} class="block rounded-lg px-4 py-2.5 text-sm font-semibold leading-snug text-white/78 transition-colors hover:bg-white/10 hover:text-white">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div class="flex items-center">
        <Button href="/#leadform" variant="orange" size="sm" class="hidden lg:inline-flex">
          <Icon name="tag" class="h-4 w-4" />
          Nhận báo giá ngay
        </Button>

        <button id="hamburger" type="button" aria-label="Menu" class="flex flex-col gap-1.5 border-none bg-none p-1.5 lg:hidden">
          <span class="block h-0.5 w-6 rounded-full bg-white"></span>
          <span class="block h-0.5 w-6 rounded-full bg-white"></span>
          <span class="block h-0.5 w-6 rounded-full bg-white"></span>
        </button>
      </div>
    </nav>
  </Container>

  <nav id="mobile-nav" class="hidden border-t border-white/10 bg-brand-darkest px-5 py-5 lg:hidden">
    {navItems.map((item) => (
      <div class="border-b border-white/8 py-3">
        <a href={item.href} class="block text-base font-semibold text-white/85">
          {item.label}
        </a>
        {item.children && (
          <div class="mt-2 grid gap-1 pl-3">
            {item.children.map((child) => (
              <a href={child.href} class="block py-1.5 text-sm font-medium text-white/60">
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
    <Button href="/#leadform" variant="orange" size="sm" class="mt-4 w-full">
      <Icon name="tag" class="h-4 w-4" />
      Nhận báo giá ngay
    </Button>
  </nav>
</header>

<script>
  const header = document.getElementById("header");
  const scrolledClasses = header?.dataset.scrolledClass.split(" ") ?? [];
  const transparentOnTop = header?.dataset.transparentOnTop === "true";

  window.addEventListener("scroll", () => {
    if (!transparentOnTop) return;

    const isScrolled = window.scrollY > 60;
    header?.classList.toggle("bg-transparent", !isScrolled);
    scrolledClasses.forEach((cls) => header?.classList.toggle(cls, isScrolled));
  });

  const hamburger = document.getElementById("hamburger");
  const mobileNav = document.getElementById("mobile-nav");
  hamburger?.addEventListener("click", () => mobileNav?.classList.toggle("hidden"));
  mobileNav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => mobileNav.classList.add("hidden"))
  );
</script>
