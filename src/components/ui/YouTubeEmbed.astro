---
const { videoId, title } = Astro.props;
---

<div class="youtube-embed aspect-video w-full overflow-hidden rounded-2xl border border-white/15 bg-brand-darkest">
  <button
    class="youtube-placeholder h-full w-full px-6 text-center text-white"
    type="button"
    data-youtube-id={videoId}
    data-youtube-title={title}
    aria-label={`Phát video: ${title}`}
  >
    <span class="youtube-play" aria-hidden="true">▶</span>
    <span class="mt-3 block text-base font-semibold">{title}</span>
    <span class="mt-1 block text-sm text-white/70">Nhấn để phát video</span>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-youtube-id]").forEach((button) => {
    button.addEventListener("click", () => {
      const videoId = button.dataset.youtubeId;
      const title = button.dataset.youtubeTitle;
      if (!videoId || !title) return;

      const frame = document.createElement("iframe");
      frame.className = "h-full w-full";
      frame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
      frame.title = title;
      frame.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
      frame.allowFullscreen = true;
      button.replaceWith(frame);
    }, { once: true });
  });
</script>

<style>
  .youtube-placeholder {
    background: linear-gradient(135deg, rgba(21, 60, 38, 0.96), rgba(45, 106, 66, 0.92));
  }

  .youtube-play {
    display: inline-flex;
    height: 4rem;
    width: 4rem;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f97316;
    padding-left: 0.2rem;
    font-size: 1.4rem;
  }

  .youtube-placeholder:hover .youtube-play,
  .youtube-placeholder:focus-visible .youtube-play {
    background: #ea650c;
  }

  .youtube-placeholder:focus-visible {
    outline: 3px solid #fff;
    outline-offset: -6px;
  }
</style>
