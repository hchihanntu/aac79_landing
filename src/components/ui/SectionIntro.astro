---
const { label, title, description, align = "center", class: className = "", dark = false } = Astro.props;

const alignClasses = align === "center" ? "mx-auto text-center" : "text-left";
---

<div data-aos="fade-up" class={`max-w-2xl ${alignClasses} ${className}`}>
  {label && (
    <span class={`inline-block rounded-full px-3.5 py-1.5 text-xs font-semibold uppercase tracking-widest ${dark ? "bg-brand-accent/15 text-brand-accent" : "bg-brand-pale text-brand-light"}`}>
      {label}
    </span>
  )}
  <h2 class={`mt-3.5 text-balance font-bold leading-tight text-[clamp(1.7rem,3.5vw,2.6rem)] ${dark ? "text-white" : "text-brand-darkest"}`}>
    {title}
  </h2>
  {description && (
    <p class={`mt-3 text-base leading-relaxed ${dark ? "text-white/70" : "text-ink-600"}`}>
      {description}
    </p>
  )}
</div>
