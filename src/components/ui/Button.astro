---
const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-lg font-bold transition-colors duration-200 whitespace-nowrap";

const variants = {
  primary: "bg-brand text-white hover:bg-brand-darkest",
  orange: "bg-orange text-white hover:bg-orange-dark",
  outline: "border-2 border-brand text-brand hover:bg-brand hover:text-white",
  ghost: "border border-white/25 text-white hover:bg-white/10",
  white: "bg-white text-brand-darkest hover:bg-brand-pale",
};

const sizes = {
  sm: "px-4 py-2.5 text-sm",
  md: "px-6 py-3.5 text-sm",
  lg: "px-7 py-4 text-base",
};

const classes = [base, variants[variant], sizes[size], className].join(" ");

const Tag = href ? "a" : "button";
---

<Tag href={href} class={classes} {...rest}>
  <slot />
</Tag>
