---
// Heroicons (outline, 24x24) — https://heroicons.com, inlined as raw SVG.
import check from "heroicons/24/outline/check.svg?raw";
import checkCircle from "heroicons/24/outline/check-circle.svg?raw";
import checkBadge from "heroicons/24/outline/check-badge.svg?raw";
import xMark from "heroicons/24/outline/x-mark.svg?raw";
import arrowRight from "heroicons/24/outline/arrow-right.svg?raw";
import arrowTrendingUp from "heroicons/24/outline/arrow-trending-up.svg?raw";
import phone from "heroicons/24/outline/phone.svg?raw";
import envelope from "heroicons/24/outline/envelope.svg?raw";
import envelopeOpen from "heroicons/24/outline/envelope-open.svg?raw";
import globeAlt from "heroicons/24/outline/globe-alt.svg?raw";
import mapPin from "heroicons/24/outline/map-pin.svg?raw";
import map from "heroicons/24/outline/map.svg?raw";
import lockClosed from "heroicons/24/outline/lock-closed.svg?raw";
import shoppingCart from "heroicons/24/outline/shopping-cart.svg?raw";
import clock from "heroicons/24/outline/clock.svg?raw";
import exclamationCircle from "heroicons/24/outline/exclamation-circle.svg?raw";
import fire from "heroicons/24/outline/fire.svg?raw";
import trophy from "heroicons/24/outline/trophy.svg?raw";
import tag from "heroicons/24/outline/tag.svg?raw";
import truck from "heroicons/24/outline/truck.svg?raw";
import chatBubble from "heroicons/24/outline/chat-bubble-left-right.svg?raw";
import shieldCheck from "heroicons/24/outline/shield-check.svg?raw";
import documentText from "heroicons/24/outline/document-text.svg?raw";
import rocketLaunch from "heroicons/24/outline/rocket-launch.svg?raw";
import cube from "heroicons/24/outline/cube.svg?raw";
import buildingOffice from "heroicons/24/outline/building-office-2.svg?raw";
import computerDesktop from "heroicons/24/outline/computer-desktop.svg?raw";
import paperAirplane from "heroicons/24/outline/paper-airplane.svg?raw";
import photo from "heroicons/24/outline/photo.svg?raw";
import scale from "heroicons/24/outline/scale.svg?raw";
import speakerXMark from "heroicons/24/outline/speaker-x-mark.svg?raw";
import rectangleStack from "heroicons/24/outline/rectangle-stack.svg?raw";
import identification from "heroicons/24/outline/identification.svg?raw";
import puzzlePiece from "heroicons/24/outline/puzzle-piece.svg?raw";
import banknotes from "heroicons/24/outline/banknotes.svg?raw";
import adjustmentsHorizontal from "heroicons/24/outline/adjustments-horizontal.svg?raw";
import sparkles from "heroicons/24/outline/sparkles.svg?raw";
import star from "heroicons/24/outline/star.svg?raw";

const icons = {
  check,
  "check-circle": checkCircle,
  "check-badge": checkBadge,
  "x-mark": xMark,
  "arrow-right": arrowRight,
  "arrow-trending-up": arrowTrendingUp,
  phone,
  envelope,
  "envelope-open": envelopeOpen,
  "globe-alt": globeAlt,
  "map-pin": mapPin,
  map,
  "lock-closed": lockClosed,
  "shopping-cart": shoppingCart,
  clock,
  "exclamation-circle": exclamationCircle,
  fire,
  trophy,
  tag,
  truck,
  "chat-bubble": chatBubble,
  "shield-check": shieldCheck,
  "document-text": documentText,
  "rocket-launch": rocketLaunch,
  cube,
  "building-office": buildingOffice,
  "computer-desktop": computerDesktop,
  "paper-airplane": paperAirplane,
  photo,
  scale,
  "speaker-x-mark": speakerXMark,
  "rectangle-stack": rectangleStack,
  identification,
  "puzzle-piece": puzzlePiece,
  banknotes,
  "adjustments-horizontal": adjustmentsHorizontal,
  sparkles,
  star,

  // Not part of Heroicons — drawn to match the same 24x24 / stroke-1.5 outline style.
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 21c-1-4.5 0-8.5 2.5-11C10 7.5 14 6 19 5c1 5-.5 9-3 11.5C13.5 19 9.5 20 5 21Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M5 21c2.5-4 5.5-7 9.5-10"/></svg>`,
  hardhat: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16.5h16M5.5 16.5V15a6.5 6.5 0 0 1 13 0v1.5M12 8.5v-3M3.5 16.5h-1A1 1 0 0 1 1.5 15.5v-.75A1 1 0 0 1 2.5 13.75h1M20.5 16.5h1a1 1 0 0 0 1-1v-.75a1 1 0 0 0-1-1h-1"/></svg>`,
  headset: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4 13v-1a8 8 0 1 1 16 0v1"/><path stroke-linecap="round" stroke-linejoin="round" d="M4 13.5a1.5 1.5 0 0 1 1.5-1.5h1A1.5 1.5 0 0 1 8 13.5v3A1.5 1.5 0 0 1 6.5 18h-1A1.5 1.5 0 0 1 4 16.5zM16 13.5a1.5 1.5 0 0 1 1.5-1.5h1a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-1a1.5 1.5 0 0 1-1.5-1.5zM18 18v.5A2.5 2.5 0 0 1 15.5 21H13"/></svg>`,
  feather: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20 4c-5 0-12.5 3-14.5 11C4.5 18.5 5 20 6 20.5 9 21 12 19 14 17M20 4c0 5-3 12.5-11 14.5M20 4 6 18"/></svg>`,
  thermometer: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14.76V4.5a2 2 0 1 1 4 0v10.26a4 4 0 1 1-4 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v6"/></svg>`,
  handshake: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2 12.5 6 9l3.5 1.5L13 8l4 1.5M2 12.5 6.5 17l2-1.5M22 12.5 18 9l-2 1.5M22 12.5 17.5 17 13 13l-2 2-3-2"/></svg>`,
};
---

<span
  class:list={["icon-svg inline-flex shrink-0", Astro.props.class ?? "h-6 w-6"]}
  set:html={icons[Astro.props.name]}
/>
