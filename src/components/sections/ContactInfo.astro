---
import Container from "@/components/ui/Container.astro";
import SectionIntro from "@/components/ui/SectionIntro.astro";
import Icon from "@/components/ui/Icon.astro";

const contactItems = [
  { icon: "map-pin", label: "Địa chỉ", html: "Lô 20, đường 18A, KĐT Lê Hồng Phong II,<br>phường Nam Nha Trang, Khánh Hòa" },
  { icon: "headset", label: "Tư vấn", html: '<a href="tel:0907523113" class="font-bold text-brand hover:text-brand-darkest">0907 523 113</a>' },
  { icon: "envelope", label: "Email", html: '<a href="mailto:aac79plus@gmail.com" class="font-bold text-brand hover:text-brand-darkest">aac79plus@gmail.com</a>' },
  { icon: "globe-alt", label: "Website", html: '<a href="https://aac79.com.vn" target="_blank" class="font-bold text-brand hover:text-brand-darkest">aac79.com.vn</a>' },
];

const { page = false } = Astro.props;
---

<section id="contact" class="py-22">
  <Container>
    <SectionIntro align="left" class={page ? "" : "sm:mx-auto sm:text-center"} title="Liên hệ với chúng tôi" />

    <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-12">
      <div data-aos="fade-up" class="lg:col-span-6">
        <h3 class="mb-5 text-xl font-bold text-brand-darkest">CÔNG TY TNHH AAC79 PLUS</h3>
        <div class="flex flex-col gap-4">
          {contactItems.map((c) => (
            <div class="flex items-start gap-3.5">
              <Icon name={c.icon} class="h-8 w-8 shrink-0 text-brand" />
              <div>
                <h5 class="mb-0.5 text-xs font-bold text-ink-600">{c.label}</h5>
                <p class="text-[0.95rem] font-medium text-ink-800" set:html={c.html} />
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 flex gap-3">
          <a href="https://www.facebook.com/betongkhiaackhanhhoa" target="_blank" title="Facebook" class="flex h-14 w-14 items-center justify-center rounded-xl bg-[#1877f2] text-white transition-opacity hover:opacity-80">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.41c0-2.51 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94"/></svg>
          </a>
          <a href="https://www.youtube.com/@BTKAACKH" target="_blank" title="YouTube" class="flex h-14 w-14 items-center justify-center rounded-xl bg-[#ff0000] text-white transition-opacity hover:opacity-80">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.6 12 3.6 12 3.6s-7.6 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.8.5 9.4.5 9.4.5s7.6 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8M9.6 15.6V8.4l6.3 3.6z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@aac79plus" target="_blank" title="TikTok" class="flex h-14 w-14 items-center justify-center rounded-xl bg-black text-white transition-opacity hover:opacity-80">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M16.6 5.8a4.3 4.3 0 0 1-3-4H10.3v13a2.6 2.6 0 1 1-1.9-2.5V8.9a6 6 0 1 0 4.6 5.9V9.4a7 7 0 0 0 4.2 1.4V7.5a4.3 4.3 0 0 1-.6-1.7"/></svg>
          </a>
          <a href="https://zalo.me/0907523113" target="_blank" title="Zalo" class="flex h-14 w-14 items-center justify-center rounded-xl bg-[#0068ff] text-white transition-opacity hover:opacity-80">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 48 48"><path d="M24 4C12.4 4 3 12.5 3 23c0 5.9 3 11.2 7.7 14.7-.3 2.3-1.2 4.6-2.7 6.6-.4.5 0 1.3.7 1.2 3.7-.5 6.7-1.9 8.9-3.3 2.3.6 4.8.9 7.4.9 11.6 0 21-8.5 21-19S35.6 4 24 4"/><path fill="#0068ff" d="M14.2 18.1h6.6c.5 0 .8.6.5 1l-4.9 6.4h4.5c.4 0 .7.3.7.7s-.3.7-.7.7h-6.9c-.5 0-.8-.6-.5-1l4.9-6.4h-4.2c-.4 0-.7-.3-.7-.7s.3-.7.7-.7m9.8-.1c.4 0 .7.3.7.7v7.5c0 .4-.3.7-.7.7s-.7-.3-.7-.7v-7.5c0-.4.3-.7.7-.7m4.6 2.3c1.7 0 3 1.4 3 3.1s-1.3 3.1-3 3.1c-.6 0-1.2-.2-1.7-.5-.1.3-.4.5-.7.5-.4 0-.7-.3-.7-.7v-4.8c0-.4.3-.7.7-.7.3 0 .6.2.7.5.5-.3 1.1-.5 1.7-.5m0 1.4c-.9 0-1.6.8-1.6 1.7s.7 1.7 1.6 1.7 1.6-.8 1.6-1.7-.7-1.7-1.6-1.7m6.2-1.4c1.7 0 3.1 1.4 3.1 3.1s-1.4 3.1-3.1 3.1-3.1-1.4-3.1-3.1 1.4-3.1 3.1-3.1m0 1.4c-.9 0-1.7.8-1.7 1.7s.8 1.7 1.7 1.7 1.7-.8 1.7-1.7-.8-1.7-1.7-1.7"/></svg>
          </a>
        </div>
      </div>

      <div data-aos="fade-up" data-aos-delay="100" class="lg:col-span-6">
        <iframe
          src="https://www.google.com/maps?q=14/7+duong+Phong+Chau,+phuong+Nam+Nha+Trang,+Khanh+Hoa&output=embed"
          title="Bản đồ AAC79 PLUS"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          class="h-full min-h-85 w-full rounded-2xl border border-ink-200 bg-ink-100"
        ></iframe>
      </div>
    </div>
  </Container>
</section>
