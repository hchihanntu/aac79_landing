---
import Container from "@/components/ui/Container.astro";
import SectionIntro from "@/components/ui/SectionIntro.astro";

const products = [
  {
    img: "product-gach-e-block.jpg",
    tag: "Tường & vách ngăn",
    title: "Gạch E-Block",
    desc: "Gạch AAC kích thước đa dạng, trọng lượng nhẹ, thi công nhanh, phù hợp mọi loại công trình.",
  },
  {
    img: "product-tam-e-panel.jpg",
    tag: "Sàn chịu lực",
    title: "Tấm E-Panel",
    desc: "Tấm sàn E-Panel có cốt thép, lắp dựng nhanh, chịu tải trọng tốt, tối ưu chi phí thi công.",
  },
  {
    img: "product-san-e-floor.jpg",
    tag: "Sàn Composite",
    title: "Sàn E-Floor",
    desc: "Sàn Composite vân gỗ, bề mặt phẳng, dễ vệ sinh, phù hợp với nhiều không gian nội thất.",
  },
  {
    img: "product-vua-keo-aac.jpg",
    tag: "Sản phẩm phụ trợ",
    title: "Vữa & keo chuyên dụng",
    desc: "Vữa xây, keo dán và vữa chuyên dụng cho AAC – đảm bảo liên kết chắc, thi công đúng kỹ thuật.",
  },
];

const { page = false } = Astro.props;
---

<section id="products" class="bg-ink-50 py-22">
  <Container>
    <SectionIntro
      align={page ? "left" : "center"}
      title="Sản phẩm chủ lực AAC79 PLUS"
      description="Đầy đủ giải pháp vật liệu cho tường, sàn và hoàn thiện."
    />

    <div class="mt-11 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {products.map((p, i) => (
        <div data-aos="fade-up" data-aos-delay={i * 90} class="group overflow-hidden rounded-2xl border border-ink-200 bg-white transition-colors hover:border-brand-light">
          <div class="h-50 overflow-hidden">
            <img src={`/images/${p.img}`} alt={p.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="p-5">
            <div class="mb-1.5 text-xs font-bold uppercase tracking-widest text-brand-light">{p.tag}</div>
            <h3 class="mb-2 text-lg font-bold text-brand-darkest">{p.title}</h3>
            <p class="mb-4 text-sm leading-relaxed text-ink-600">{p.desc}</p>
            <a href="/#leadform" class="inline-flex items-center gap-2 rounded-lg border-2 border-brand px-5 py-2.5 text-sm font-bold text-brand transition-colors hover:bg-brand hover:text-white">
              Xem chi tiết & báo giá
            </a>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
