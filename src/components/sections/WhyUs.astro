---
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";

const items = [
  { icon: "puzzle-piece", title: "Không chỉ bán vật liệu - Chúng tôi cung cấp giải pháp", desc: "Tư vấn, thiết kế và cung cấp giải pháp từ chi tiết đến tổng thể cho từng công trình." },
  { icon: "hardhat", title: "Có năng lực thi công thực tế", desc: "Có kinh nghiệm nhiều năm, am hiểu vật liệu AAC, đảm bảo đúng theo yêu cầu kỹ thuật." },
  { icon: "identification", title: "Tư vấn kỹ thuật đồng hành cùng dự án", desc: "Đội ngũ kỹ sư có chuyên môn hỗ trợ từ khảo sát đến nghiệm thu, tránh sai sót gây lãng phí." },
  { icon: "building-office", title: "Phù hợp mọi loại công trình", desc: "Dân dụng, khách sạn, nhà xưởng, dự án công nghiệp – AAC79 PLUS có kinh nghiệm với tất cả." },
  { icon: "arrow-trending-up", title: "Tối ưu chi phí & tiến độ", desc: "Vật liệu nhẹ + thi công nhanh = tiết kiệm chi phí tổng thể và rút ngắn thời gian dự án." },
];

const stats = [
  { value: "5+", label: "Năm kinh nghiệm" },
  { value: "100+", label: "Dự án hoàn thành" },
  { value: "KH", label: "Khánh Hòa" },
  { value: "24/7", label: "Hỗ trợ kỹ thuật" },
];
---

<section id="whyus" class="bg-gradient-to-br from-brand-darkest to-brand-dark py-22">
  <Container>
    <div class="grid grid-cols-1 gap-11 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7">
        <span data-aos="fade-up" class="inline-block rounded-full bg-brand-accent/15 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand-accent">Tại sao chọn chúng tôi</span>
        <h2 data-aos="fade-up" data-aos-delay="60" class="mt-3 text-balance text-[clamp(1.7rem,3.5vw,2.6rem)] font-bold leading-tight text-white">
          Đối tác xây dựng toàn diện – không chỉ là nhà cung cấp
        </h2>

        <div class="mt-7 flex flex-col gap-3.5">
          {items.map((item, i) => (
            <div data-aos="fade-up" data-aos-delay={100 + i * 70} class="flex items-start gap-4 rounded-xl border border-white/10 bg-white/6 p-5 transition-colors hover:border-brand-accent/30 hover:bg-brand-accent/12">
              <Icon name={item.icon} class="h-9 w-9 shrink-0 text-brand-accent" />
              <div>
                <h4 class="mb-1 text-sm font-bold text-white">{item.title}</h4>
                <p class="text-sm leading-relaxed text-white/62">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div data-aos="fade-up" data-aos-delay="150" class="relative lg:col-span-5">
        <img src="/images/whyus-doi-ngu-aac79-plus.jpg" alt="Đội ngũ AAC79 PLUS" class="h-[420px] w-full rounded-2xl object-cover lg:h-[500px]" />
        <div class="absolute inset-x-5 bottom-5 grid grid-cols-2 gap-3">
          {stats.map((s) => (
            <div class="rounded-lg bg-[#0f2d19]/88 p-4 text-center backdrop-blur">
              <strong class="block text-2xl font-bold leading-none text-brand-accent">{s.value}</strong>
              <span class="text-xs text-white/70">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>
