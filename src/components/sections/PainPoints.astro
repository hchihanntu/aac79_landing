---
import Container from "@/components/ui/Container.astro";
import SectionIntro from "@/components/ui/SectionIntro.astro";
import Icon from "@/components/ui/Icon.astro";

const pains = [
  { icon: "scale", title: "Tường nặng, tăng tải trọng", desc: "Tăng chi phí móng và kết cấu, khó tối ưu ngân sách tổng thể." },
  { icon: "clock", title: "Thi công chậm", desc: "Mất thời gian, tốn nhân công, dễ trễ tiến độ bàn giao." },
  { icon: "thermometer", title: "Cách nhiệt kém", desc: "Không gian nóng, chi phí điện vận hành tăng cao." },
  { icon: "exclamation-circle", title: "Thiếu đồng bộ vật liệu", desc: "Khó kiểm soát chất lượng khi mua từ nhiều nguồn khác nhau." },
];
---

<section id="pain" class="bg-ink-50 py-22">
  <Container>
    <SectionIntro align="left" title="Công trình của bạn đang gặp vấn đề gì?" />

    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {pains.map((p, i) => (
        <div data-aos="fade-up" data-aos-delay={i * 80} class="rounded-xl border-l-4 border-red-500 bg-white p-6">
          <Icon name={p.icon} class="mb-4 h-10 w-10 text-red-500" />
          <h4 class="mb-1.5 font-bold text-ink-800">{p.title}</h4>
          <p class="text-sm leading-relaxed text-ink-600">{p.desc}</p>
        </div>
      ))}
    </div>

    <div data-aos="fade-up" class="mt-10 flex flex-col items-center gap-5 rounded-2xl bg-brand-darkest/92 px-9 py-8 text-center text-white sm:flex-row sm:text-left">
      <Icon name="arrow-right" class="h-11 w-11 shrink-0 text-brand-accent" />
      <p class="text-lg font-medium leading-relaxed text-white/72">
        <strong class="font-bold text-brand-accent">AAC79 PLUS cung cấp giải pháp đồng bộ</strong> từ vật liệu đến thi công và tư vấn kỹ thuật, giúp tối ưu tiến độ, chất lượng và chi phí.
      </p>
    </div>
  </Container>
</section>
