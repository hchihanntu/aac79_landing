---
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";

const benefits = [
  { icon: "feather", title: "Siêu nhẹ", desc: "Nhẹ hơn 3-5 lần so với vật liệu truyền thống." },
  { icon: "thermometer", title: "Cách nhiệt", desc: "Giảm tải cho điều hòa, tăng tiện nghi sử dụng." },
  { icon: "speaker-x-mark", title: "Cách âm", desc: "Phù hợp nhà ở, văn phòng, khách sạn." },
  { icon: "fire", title: "Chống cháy", desc: "Đáp ứng yêu cầu PCCC theo tiêu chuẩn." },
  { icon: "rocket-launch", title: "Thi công nhanh", desc: "Rút ngắn tiến độ và tiết kiệm nhân công." },
  { icon: "leaf", title: "Vật liệu xanh", desc: "Giảm phát thải, hướng tới công trình bền vững." },
];
---

<section id="benefits" class="relative overflow-hidden bg-gradient-to-b from-brand-darkest to-[#0f2d19] py-22">
  <Container class="relative">
    <div data-aos="fade-up" class="mx-auto max-w-2xl text-center">
      <h2 class="text-balance text-[clamp(1.7rem,3.5vw,2.6rem)] font-bold leading-tight text-white">Vật liệu xanh – hiệu quả vượt trội</h2>
      <p class="mt-3 text-base leading-relaxed text-white/70">Bê tông khí chưng áp AAC được công nhận là vật liệu xanh VGBC.</p>
    </div>

    <div class="mt-11 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {benefits.map((b, i) => (
        <div
          data-aos="fade-up"
          data-aos-delay={(i % 3) * 80}
          class="rounded-xl border border-white/10 bg-white/6 p-7 text-center transition-colors hover:border-brand-accent/40 hover:bg-brand-accent/12"
        >
          <Icon name={b.icon} class="mx-auto mb-4 h-12 w-12 text-brand-accent" />
          <h4 class="mb-2 text-lg font-bold text-white">{b.title}</h4>
          <p class="text-sm leading-relaxed text-white/60">{b.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
